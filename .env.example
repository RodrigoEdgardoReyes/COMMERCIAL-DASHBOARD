# =============================================================================
#                        Backend – Variables de entorno
# =============================================================================

POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=dashboard

# CADENA DE CONEXION
# NOTA: En producción, esta URL debería apuntar a la base de datos real (no al contenedor "db")
DATABASE_URL=postgresql://user:pass@db:1234/dashboard

# PORT
BACKEND_PORT=3001

# =============================================================================
#                        Frontend – Variables de entorno
# =============================================================================

# PUERTO EN EL QUE CORRE EL FRONTEND
PORT=3000

# URL del backend accesible desde el navegador
NEXT_PUBLIC_API_URL=http://localhost:3001

# Entorno de ejecución
NODE_ENV=development